<Window x:Class="DopeCompanion.App.DisplayCastOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:viewModels="clr-namespace:DopeCompanion.App.ViewModels"
        xmlns:models="clr-namespace:DopeCompanion.Core.Models;assembly=DopeCompanion.Core"
        x:ClassModifier="internal"
        Title="DOPE Companion Cast Controls"
        Width="1120"
        Height="720"
        MinWidth="520"
        MinHeight="320"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Foreground="{StaticResource InkBrush}">
    <Window.Resources>
        <Style x:Key="OverlayCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="OverlayHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="OverlayPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="OverlayFocusLayerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="OverlayGripStyle" TargetType="primitives:Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:Thumb">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayReservedPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:SingleValueRowViewModel}">
            <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="14"
                     Padding="8,5" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ToggleRowViewModel}">
            <CheckBox Content="Enabled"
                      IsChecked="{Binding Value}"
                      FontSize="14"
                      VerticalAlignment="Center" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ChoiceRowViewModel}">
            <ComboBox ItemsSource="{Binding Options}"
                      SelectedItem="{Binding SelectedOption}"
                      FontSize="14"
                      MinWidth="120" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LiveSessionSettingViewModel}">
            <Border x:Name="SidebarSettingCard"
                    Margin="0,0,0,8"
                    Padding="8"
                    Background="{StaticResource SurfaceTintBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    ToolTip="{Binding SidebarStateDetail}">
                <StackPanel>
                    <TextBlock x:Name="SidebarSettingLabel"
                               Text="{Binding Label}"
                               FontSize="14"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <ContentPresenter Content="{Binding Row}"
                                      Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding SidebarState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Verified}">
                    <Setter TargetName="SidebarSettingCard" Property="Background" Value="{StaticResource StatusSuccessSoftBrush}" />
                    <Setter TargetName="SidebarSettingCard" Property="BorderBrush" Value="{StaticResource StatusSuccessBrush}" />
                    <Setter TargetName="SidebarSettingLabel" Property="TextBlock.Foreground" Value="{StaticResource StatusSuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SidebarState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Pending}">
                    <Setter TargetName="SidebarSettingCard" Property="Background" Value="{StaticResource StatusWarningSoftBrush}" />
                    <Setter TargetName="SidebarSettingCard" Property="BorderBrush" Value="{StaticResource StatusWarningBrush}" />
                    <Setter TargetName="SidebarSettingLabel" Property="TextBlock.Foreground" Value="{StaticResource StatusWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SidebarState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Failed}">
                    <Setter TargetName="SidebarSettingCard" Property="Background" Value="{StaticResource StatusFailureSoftBrush}" />
                    <Setter TargetName="SidebarSettingCard" Property="BorderBrush" Value="{StaticResource StatusFailureBrush}" />
                    <Setter TargetName="SidebarSettingLabel" Property="TextBlock.Foreground" Value="{StaticResource StatusFailureBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LiveSessionCastFocusLayerOptionViewModel}">
            <Button x:Name="FocusLayerButton"
                    Content="{Binding Label}"
                    ToolTip="{Binding Description}"
                    Command="{Binding DataContext.SelectLiveSessionCastFocusLayerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Value}"
                    Style="{StaticResource OverlayFocusLayerButtonStyle}"
                    PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown" />

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="FocusLayerButton" Property="Background" Value="{StaticResource FocusBlueBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                        <Condition Binding="{Binding State}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Verified}" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="FocusLayerButton" Property="Background" Value="{StaticResource StatusSuccessSoftBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="BorderBrush" Value="{StaticResource StatusSuccessBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="Foreground" Value="{StaticResource StatusSuccessBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                        <Condition Binding="{Binding State}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Pending}" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="FocusLayerButton" Property="Background" Value="{StaticResource StatusWarningSoftBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="BorderBrush" Value="{StaticResource StatusWarningBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="Foreground" Value="{StaticResource StatusWarningBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                        <Condition Binding="{Binding State}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Failed}" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="FocusLayerButton" Property="Background" Value="{StaticResource StatusFailureSoftBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="BorderBrush" Value="{StaticResource StatusFailureBrush}" />
                    <Setter TargetName="FocusLayerButton" Property="Foreground" Value="{StaticResource StatusFailureBrush}" />
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LiveSessionCastSurfaceModeOptionViewModel}">
            <Button x:Name="SurfaceModeButton"
                    Content="{Binding Label}"
                    ToolTip="{Binding Description}"
                    Command="{Binding DataContext.SelectLiveSessionCastSurfaceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Value}"
                    Style="{StaticResource OverlayFocusLayerButtonStyle}"
                    PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown" />

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="SurfaceModeButton" Property="Background" Value="{StaticResource FocusBlueBrush}" />
                    <Setter TargetName="SurfaceModeButton" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                    <Setter TargetName="SurfaceModeButton" Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootChrome"
          SnapsToDevicePixels="True">
        <Border Margin="2"
                CornerRadius="10"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                Background="#01060A20"
                IsHitTestVisible="False" />

        <Grid Margin="2"
              IsHitTestVisible="False">
            <Border Width="26"
                    Height="3"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
        </Grid>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border x:Name="HeaderChrome"
                    Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="12,10"
                    PreviewMouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <TextBlock Text="{Binding LiveSessionCastSurfaceModeLabel}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="CaptureSourceText"
                                   Text="{Binding LiveSessionCastSourceLabel}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource OverlayCaptionStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Center"
                                    Margin="0,0,8,0">
                            <TextBlock Text="Window size"
                                       Style="{StaticResource OverlayCaptionStyle}" />
                            <TextBlock x:Name="WindowSizeText"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="16"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <Button x:Name="MinimizeButton"
                                Content="Minimize"
                                Style="{StaticResource OverlayHeaderButtonStyle}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                Click="OnMinimizeWindowClicked" />
                        <Button x:Name="FullscreenButton"
                                Content="Full Size"
                                Style="{StaticResource OverlayHeaderButtonStyle}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                Click="OnToggleFullscreenWindowClicked" />
                        <Button x:Name="StopButton"
                                Content="Stop"
                                Style="{StaticResource OverlayHeaderButtonStyle}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                Click="OnStopWindowClicked" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="3"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,8,0">
                            <TextBlock Text="Main view"
                                       Style="{StaticResource OverlayCaptionStyle}" />
                            <TextBlock Text="{Binding LiveSessionCastSurfaceModeLabel}"
                                       Margin="0,2,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       ToolTip="{Binding LiveSessionCastSurfaceModeDetail}" />
                        </StackPanel>

                        <ItemsControl Grid.Column="2"
                                      ItemsSource="{Binding LiveSessionCastSurfaceOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <StackPanel Grid.Column="4"
                                    Margin="0,0,8,0">
                            <TextBlock Text="Layer focus"
                                       Style="{StaticResource OverlayCaptionStyle}" />
                            <TextBlock Text="{Binding LiveSessionCastFocusLayerStatusLabel}"
                                       Margin="0,2,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       ToolTip="{Binding LiveSessionCastFocusLayerStatusDetail}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveSessionCastFocusLayerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Verified}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastFocusLayerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Pending}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastFocusLayerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Failed}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusFailureBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <ItemsControl Grid.Column="6"
                                      ItemsSource="{Binding LiveSessionCastFocusLayerOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <StackPanel Grid.Column="8"
                                    MinWidth="154">
                            <TextBlock Text="Audio trigger"
                                       Style="{StaticResource OverlayCaptionStyle}" />
                            <TextBlock Text="{Binding LiveSessionCastAudioTriggerStatusLabel}"
                                       Margin="0,2,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       ToolTip="{Binding LiveSessionCastAudioTriggerStatusDetail}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Verified}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Pending}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Failed}">
                                                <Setter Property="Foreground" Value="{StaticResource StatusFailureBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button Content="{Binding LiveSessionCastAudioTriggerActionLabel}"
                                    Margin="0,8,0,0"
                                    Command="{Binding ToggleLiveSessionCastAudioTriggerCommand}"
                                    ToolTip="{Binding LiveSessionCastAudioTriggerStatusDetail}"
                                    PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OverlayFocusLayerButtonStyle}">
                                        <Setter Property="MinWidth" Value="104" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Verified}">
                                                <Setter Property="Background" Value="{StaticResource StatusSuccessSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource StatusSuccessBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource StatusSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Pending}">
                                                <Setter Property="Background" Value="{StaticResource StatusWarningSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource StatusWarningBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LiveSessionCastAudioTriggerStatusState}" Value="{x:Static viewModels:LiveSessionSettingSidebarState.Failed}">
                                                <Setter Property="Background" Value="{StaticResource StatusFailureSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource StatusFailureBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource StatusFailureBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="VideoViewportSlot"
                    Grid.Row="2"
                    Grid.Column="0"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLiveSessionCastRenderViewMode}" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Image Source="{Binding LiveSessionCastFocusedLayerPreviewImage}"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLiveSessionCastRenderViewMode}" Value="True" />
                                            <Condition Binding="{Binding HasLiveSessionCastFocusedLayerPreviewImage}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <TextBlock Text="Waiting for the next direct Quest Render View frame."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource OverlayCaptionStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLiveSessionCastRenderViewMode}" Value="True" />
                                            <Condition Binding="{Binding HasLiveSessionCastFocusedLayerPreviewImage}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border x:Name="SidebarChrome"
                    Grid.Row="2"
                    Grid.Column="2"
                    Style="{StaticResource OverlayReservedPanelStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowLiveSessionCastSidebarRenderView}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Render View"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding LiveSessionCastFocusedLayerPreviewSummary}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   ToolTip="{Binding LiveSessionCastFocusedLayerPreviewDetail}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LiveSessionCastFocusedLayerPreviewLevel}" Value="{x:Static models:OperationOutcomeKind.Success}">
                                            <Setter Property="Foreground" Value="{StaticResource StatusSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionCastFocusedLayerPreviewLevel}" Value="{x:Static models:OperationOutcomeKind.Warning}">
                                            <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LiveSessionCastFocusedLayerPreviewLevel}" Value="{x:Static models:OperationOutcomeKind.Failure}">
                                            <Setter Property="Foreground" Value="{StaticResource StatusFailureBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding LiveSessionCastFocusedLayerPreviewDetail}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource OverlayCaptionStyle}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Height="162"
                            Padding="6"
                            Background="{StaticResource SurfaceTintBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            ToolTip="{Binding LiveSessionCastFocusedLayerPreviewArtifactPath}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowLiveSessionCastSidebarRenderView}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Image Source="{Binding LiveSessionCastFocusedLayerPreviewImage}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLiveSessionCastFocusedLayerPreviewImage}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <TextBlock Text="Waiting for the next direct Quest Render View frame."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource OverlayCaptionStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLiveSessionCastFocusedLayerPreviewImage}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Live tweak values"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Green verified. White staged. Yellow requested. Red failed."
                                   Margin="0,4,0,0"
                                   Style="{StaticResource OverlayCaptionStyle}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="6"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LiveSessionCastSidebarSettings}" />
                    </ScrollViewer>

                    <Button Grid.Row="8"
                            Content="Apply"
                            Command="{Binding ApplyLiveSessionRuntimeConfigCommand}"
