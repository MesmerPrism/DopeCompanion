<Window x:Class="DopeCompanion.App.DisplayCastOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        x:ClassModifier="internal"
        Title="DOPE Companion Cast Controls"
        Width="1120"
        Height="720"
        MinWidth="520"
        MinHeight="320"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Foreground="{StaticResource InkBrush}">
    <Window.Resources>
        <Style x:Key="OverlayCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="OverlayHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="OverlayGripStyle" TargetType="primitives:Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:Thumb">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootChrome"
          SnapsToDevicePixels="True">
        <Border Margin="2"
                CornerRadius="10"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                Background="#01060A20"
                IsHitTestVisible="False" />

        <Grid Margin="2"
              IsHitTestVisible="False">
            <Border Width="26"
                    Height="3"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />

            <Border Width="26"
                    Height="3"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="26"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource FocusBlueBrush}"
                    CornerRadius="2" />
        </Grid>

        <Border x:Name="HeaderChrome"
                Margin="14,14,14,0"
                VerticalAlignment="Top"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12,10"
                PreviewMouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Display 0 cast"
                               FontSize="22"
                               FontWeight="Bold" />
                    <TextBlock x:Name="CaptureSourceText"
                               Margin="0,4,0,0"
                               Style="{StaticResource OverlayCaptionStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <TextBlock Text="Window size"
                                   Style="{StaticResource OverlayCaptionStyle}" />
                        <TextBlock x:Name="WindowSizeText"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="16"
                                   FontWeight="Bold" />
                    </StackPanel>

                    <Button x:Name="MinimizeButton"
                            Content="Minimize"
                            Style="{StaticResource OverlayHeaderButtonStyle}"
                            PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                            Click="OnMinimizeWindowClicked" />
                    <Button x:Name="FullscreenButton"
                            Content="Full Size"
                            Style="{StaticResource OverlayHeaderButtonStyle}"
                            PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                            Click="OnToggleFullscreenWindowClicked" />
                    <Button x:Name="StopButton"
                            Content="Stop"
                            Style="{StaticResource OverlayHeaderButtonStyle}"
                            PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                            Click="OnStopWindowClicked" />
                </StackPanel>
            </Grid>
        </Border>

        <primitives:Thumb x:Name="LeftGrip"
                          HorizontalAlignment="Left"
                          Width="12"
                          Cursor="SizeWE"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="RightGrip"
                          HorizontalAlignment="Right"
                          Width="12"
                          Cursor="SizeWE"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="TopGrip"
                          VerticalAlignment="Top"
                          Height="12"
                          Cursor="SizeNS"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomGrip"
                          VerticalAlignment="Bottom"
                          Height="12"
                          Cursor="SizeNS"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />

        <primitives:Thumb x:Name="TopLeftGrip"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Width="22"
                          Height="22"
                          Cursor="SizeNWSE"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="TopRightGrip"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Width="22"
                          Height="22"
                          Cursor="SizeNESW"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomLeftGrip"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Bottom"
                          Width="22"
                          Height="22"
                          Cursor="SizeNESW"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomRightGrip"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Width="22"
                          Height="22"
                          Cursor="SizeNWSE"
                          Style="{StaticResource OverlayGripStyle}"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
    </Grid>
</Window>
