<Window x:Class="DopeCompanion.App.FullDiagnosticHarnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:DopeCompanion.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource InkBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:OutcomeKindToBrushConverter x:Key="OutcomeKindToBrush" />
        <local:OutcomeKindToSoftBrushConverter x:Key="OutcomeKindToSoftBrush" />
        <local:StatusDetailFormatterConverter x:Key="StatusDetailFormatter" />

        <Style x:Key="HarnessInsetPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="HarnessMicroLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MicroCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HarnessCodeStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Background="{Binding Level, Converter={StaticResource OutcomeKindToSoftBrush}}"
                BorderBrush="{Binding Level, Converter={StaticResource OutcomeKindToBrush}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Full Diagnostic Harness"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding Summary}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}"
                               Style="{StaticResource SectionCaptionStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding StatusLine}"
                               Style="{StaticResource MicroCaptionStyle}"
                               Margin="0,10,0,0" />
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Height="14"
                                 Margin="0,12,0,0"
                                 Value="{Binding ProgressPercent, Mode=OneWay}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource HarnessInsetPanelStyle}"
                        BorderBrush="{StaticResource FocusBlueBrush}">
                    <StackPanel>
                        <TextBlock Text="Current step"
                                   Style="{StaticResource HarnessMicroLabelStyle}" />
                        <TextBlock Text="{Binding CurrentStepProgressLabel}"
                                   Style="{StaticResource HarnessCodeStyle}"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CurrentStepLabel}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FocusBlueBrush}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentStepSummary}"
                                   Style="{StaticResource SectionCaptionStyle}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentStepDetail, Converter={StaticResource StatusDetailFormatter}}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Execution steps"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="The window lists the stable public harness stages in the order they run and highlights whichever stage is active right now."
                                       Style="{StaticResource SectionCaptionStyle}" />
                            <ItemsControl ItemsSource="{Binding Steps}"
                                          Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PanelBorderStyle}"
                                                Margin="0,0,0,12"
                                                Background="{Binding SoftBrush}"
                                                BorderBrush="{Binding AccentBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="58" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Style="{StaticResource HarnessInsetPanelStyle}"
                                                        Background="{StaticResource PanelBrush}"
                                                        BorderBrush="{Binding AccentBrush}"
                                                        Padding="10,8"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding OrdinalLabel}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding AccentBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Label}"
                                                               Style="{StaticResource SectionTitleStyle}" />
                                                    <TextBlock Text="{Binding SupportingText}"
                                                               Style="{StaticResource SectionCaptionStyle}"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail, Converter={StaticResource StatusDetailFormatter}}"
                                                               Style="{StaticResource MicroCaptionStyle}"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusLabel}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding AccentBrush}"
                                                           Margin="12,0,0,0"
                                                           VerticalAlignment="Top" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Outputs"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Once the harness finishes, the buttons below take you straight to the generated report assets."
                                       Style="{StaticResource SectionCaptionStyle}" />

                            <TextBlock Text="Harness folder"
                                       Style="{StaticResource HarnessMicroLabelStyle}"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding HarnessFolderPath}"
                                       Style="{StaticResource HarnessCodeStyle}"
                                       Margin="0,6,0,0" />

                            <TextBlock Text="Shareable bundle"
                                       Style="{StaticResource HarnessMicroLabelStyle}"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding HarnessBundlePath}"
                                       Style="{StaticResource HarnessCodeStyle}"
                                       Margin="0,6,0,0" />

                            <TextBlock Text="Diagnostics PDF"
                                       Style="{StaticResource HarnessMicroLabelStyle}"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding ReportPdfPath}"
                                       Style="{StaticResource HarnessCodeStyle}"
                                       Margin="0,6,0,0" />

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Open Harness Folder"
                                        Command="{Binding OpenHarnessFolderCommand}" />
                                <Button Content="Open Harness Bundle"
                                        Command="{Binding OpenHarnessBundleCommand}" />
                                <Button Content="Open Report PDF"
                                        Command="{Binding OpenReportPdfCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="What this window fixes"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="The full harness now opens its own progress surface immediately instead of only updating the inline Windows Environment summary after the run finishes."
                                       Style="{StaticResource SectionCaptionStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Close"
                    Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>
